# ─── Copy this file to .env.local and fill in real values where noted ───
# .env.local is gitignored. Never commit real secrets.

# Database (local dev = SQLite; production = PostgreSQL)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="generate with: openssl rand -base64 32  (or node crypto)"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional for local dev — leave blank to disable the Google button)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe — use TEST keys for local dev (sk_test_… / pk_test_…)
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_ID_SINGLE="price_single_xxx"
STRIPE_PRICE_ID_ANNUAL="price_annual_xxx"
NEXT_PUBLIC_STRIPE_PRICE_ID_SINGLE="price_single_xxx"
NEXT_PUBLIC_STRIPE_PRICE_ID_ANNUAL="price_annual_xxx"

# AWS S3 document storage (stubbed locally — see lib/storage)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET_NAME=""
AWS_REGION="eu-west-2"

# Email (Resend) — stubbed locally (emails are logged to console)
RESEND_API_KEY=""
EMAIL_FROM="PPT Wills <noreply@example.com>"

# Cron — protects /api/cron/* (Vercel injects this bearer on scheduled runs)
CRON_SECRET="generate a long random string"

# Feature flags
# When true, the app uses local stubs for S3/email/Stripe instead of live services.
USE_LOCAL_STUBS="true"
